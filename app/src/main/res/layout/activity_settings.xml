<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/pref_back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginStart="14dp"
            android:background="@color/white"
            android:contentDescription="@string/pref_button"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_back"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="2dp"
            android:layout_gravity="center"
            android:text="@string/pref_button"
            android:textColor="@color/yp_black"
            android:textSize="@dimen/main_text_size"/>
        </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/pref_line_height"
                android:layout_marginStart="@dimen/main_button_margin_side"
                android:layout_marginTop="24dp"

                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:text="@string/choose_theme"
                    android:textColor="@color/yp_black"
                    android:textSize="@dimen/pref_text_size"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/main_button_margin_side"
                    android:checked="true"
                    />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/pref_line_height"
                    android:layout_marginStart="@dimen/main_button_margin_side"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/share_app"
                        android:textColor="@color/yp_black"
                        android:textSize="@dimen/pref_text_size"/>

                    <View
                       android:layout_width="0dp"
                       android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <ImageButton
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/main_button_margin_side"
                        android:contentDescription="@string/share_app"
                        android:src="@drawable/ic_share"
                        android:background="@android:color/transparent"
                        app:tint="@color/yp_text_gray" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/pref_line_height"
                    android:layout_marginStart="@dimen/main_button_margin_side"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/support"
                        android:textColor="@color/yp_black"
                        android:textSize="@dimen/pref_text_size" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                    <ImageButton
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/main_button_margin_side"
                        android:contentDescription="@string/support"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_support"
                        app:tint="@color/yp_text_gray"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/pref_line_height"
                        android:layout_marginStart="@dimen/main_button_margin_side"

                        android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/license_agreement"
                        android:textColor="@color/yp_black"
                        android:textSize="@dimen/pref_text_size" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/main_button_margin_side"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrow"
                        app:tint="@color/yp_text_gray" />
            </LinearLayout>


           </LinearLayout>
















