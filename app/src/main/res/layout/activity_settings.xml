<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="0dp">

        <ImageButton
            android:id="@+id/pref_back_button"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/pref_button"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/yp_black" />

        <TextView
            android:layout_width="120dp"
            android:layout_height="26dp"
            android:layout_marginStart="64dp"
            android:layout_marginTop="14dp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="@string/pref_button"
            android:textColor="@color/yp_black"
            android:textSize="@dimen/main_text_size"/>
    </FrameLayout>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/pref_line_height"
        android:layout_marginTop="80dp"
        android:background="@color/white">

        <TextView
            android:layout_width="300dp"
            android:layout_height="19dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="@string/choose_theme"
            android:textColor="@color/yp_black"
            android:textSize="@dimen/pref_text_size"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/theme_switch"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:checked="true"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:showText="false" />

        </FrameLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/pref_line_height"
            android:layout_marginTop="141dp"
            android:background="@color/white"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="300dp"
                android:layout_height="19dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="21dp"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:text="@string/share_app"
                android:textColor="@color/yp_black"
                android:textSize="@dimen/pref_text_size" />

            <ImageButton
                android:layout_width="@dimen/icon_button_size"
                android:layout_height="@dimen/icon_button_size"
                android:layout_gravity="end"
                android:layout_marginTop="7dp"
                android:contentDescription="@string/share_app"
                android:padding="12dp"
                android:src="@drawable/ic_share"
                android:background="transparent"
                app:tint="@color/yp_text_gray" />

        </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="61dp"
        android:layout_marginTop="202dp"
        android:background="@color/white"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="300dp"
            android:layout_height="19dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="21dp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="@string/support"
            android:textColor="@color/yp_black"
            android:textSize="@dimen/pref_text_size" />

        <ImageButton
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:layout_gravity="end"
            android:layout_marginTop="7dp"
            android:contentDescription="@string/support"
            android:padding="12dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_support"
            app:tint="@color/yp_text_gray"/>
        </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/pref_line_height"
        android:layout_marginTop="263dp"
        android:background="@color/white"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="300dp"
            android:layout_height="19dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="21dp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="@string/license_agreement"
            android:textColor="@color/yp_black"
            android:textSize="@dimen/pref_text_size" />

        <ImageView
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:layout_gravity="end"
            android:layout_marginTop="7dp"
            android:contentDescription="@null"
            android:padding="12dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow"
            app:tint="@color/yp_text_gray"/>
    </FrameLayout>


</FrameLayout>
















